generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int      @id @default(autoincrement())
  username    String   @unique
  password    String
  role        Role
  fullName    String
  email       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  sessions       Session[]
  tickets        Ticket[]
  systemLogs     SystemLog[]
  messages       Message[]
  sentMessages   Message[] @relation("SentMessages")
  assignedLaboratories Laboratory[]
  labSchedules   LabSchedule[]
  createdGroups  Group[]
  groupMemberships GroupMember[]
}

model Laboratory {
  id          Int      @id @default(autoincrement())
  name        String
  location    String?
  building    String?  // Building A, Building B, etc.
  roomNumber  String
  capacity    Int
  status      LabStatus @default(ACTIVE)
  assignedInstructorId Int?
  // Schedule-based assignment fields
  scheduleDay     String?  // Monday, Tuesday, etc.
  scheduleTimeSlot String? // 1:00 PM - 3:00 PM, etc.
  scheduleClass   String?  // BSIT 3A, etc.
  scheduleSubjectCode String? // AIA 313, etc.
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  computers  Computer[]
  sessions   Session[]
  assignedInstructor User? @relation(fields: [assignedInstructorId], references: [id])
  schedules  LabSchedule[]
}

model Computer {
  id              Int      @id @default(autoincrement())
  name            String
  seatNumber      Int?
  ipAddress       String?
  macAddress      String?
  status          ComputerStatus @default(OFFLINE)
  isLocked        Boolean  @default(false)
  laboratoryId    Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Hardware Specifications
  processor       String?  // CPU model
  ram             String?  // RAM size (e.g., "16GB")
  storageType     String?  // SSD or HDD
  storageSize     String?  // Storage size (e.g., "512GB")
  gpu             String?  // GPU model (optional)
  osVersion       String?  // Operating System version
  
  // Relations
  laboratory Laboratory @relation(fields: [laboratoryId], references: [id], onDelete: Cascade)
  sessionStudents SessionStudent[]
  software  ComputerSoftware[]
}

model Session {
  id              Int      @id @default(autoincrement())
  name            String
  instructorId    Int
  laboratoryId    Int
  startTime       DateTime
  endTime         DateTime?
  status          SessionStatus @default(ACTIVE)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  instructor      User             @relation(fields: [instructorId], references: [id])
  laboratory      Laboratory       @relation(fields: [laboratoryId], references: [id])
  sessionStudents SessionStudent[]
}

model SessionStudent {
  id          Int      @id @default(autoincrement())
  sessionId   Int
  studentId   Int
  computerId  Int
  checkInTime DateTime @default(now())
  checkOutTime DateTime?
  status      StudentSessionStatus @default(ACTIVE)

  // Relations
  session   Session   @relation(fields: [sessionId], references: [id])
  computer  Computer  @relation(fields: [computerId], references: [id])
}

model Ticket {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @db.Text
  status      TicketStatus @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  category    String
  createdBy   Int
  assignedTo  Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  creator     User     @relation(fields: [createdBy], references: [id])
}

model SystemLog {
  id          Int      @id @default(autoincrement())
  action      String
  description String?
  userId      Int?
  ipAddress   String?
  createdAt   DateTime @default(now())

  // Relations
  user        User?    @relation(fields: [userId], references: [id])
}

model Message {
  id          Int      @id @default(autoincrement())
  content     String   @db.Text
  senderId    Int
  receiverId  Int?
  groupId     Int?
  isBroadcast Boolean  @default(false)
  status      MessageStatus @default(SENT)
  attachments String?  @db.Text // JSON array of file URLs
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  sender      User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver    User?    @relation(fields: [receiverId], references: [id])
  group       Group?   @relation(fields: [groupId], references: [id])
}

model Group {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  createdBy   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  creator     User     @relation(fields: [createdBy], references: [id])
  members     GroupMember[]
  messages    Message[]
}

model GroupMember {
  id        Int      @id @default(autoincrement())
  groupId   Int
  userId    Int
  role      GroupRole @default(MEMBER)
  joinedAt  DateTime @default(now())

  // Relations
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum GroupRole {
  ADMIN
  MEMBER
}

model Inventory {
  id          Int      @id @default(autoincrement())
  name        String
  category    String
  quantity    Int      @default(0)
  unit        String
  location    String?
  status      InventoryStatus @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Role {
  ADMIN
  INSTRUCTOR
  STUDENT
}

enum LabStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum ComputerStatus {
  ONLINE
  OFFLINE
  IN_USE
  IDLE
  MAINTENANCE
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum StudentSessionStatus {
  ACTIVE
  COMPLETED
  ABSENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum InventoryStatus {
  ACTIVE
  INACTIVE
  DEPLETED
}

// Lab Schedule for instructor assignments
model LabSchedule {
  id              Int      @id @default(autoincrement())
  laboratoryId    Int
  day             String   // Monday, Tuesday, etc.
  startTime       String   // 13:00 (24-hour format)
  endTime         String   // 15:00 (24-hour format)
  instructorId    Int
  className       String   // BSIT 3A, etc.
  subjectCode     String   // AIA 313, etc.
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  laboratory      Laboratory @relation(fields: [laboratoryId], references: [id], onDelete: Cascade)
  instructor      User       @relation(fields: [instructorId], references: [id])
}

// Computer Software tracking
model ComputerSoftware {
  id              Int      @id @default(autoincrement())
  computerId      Int
  softwareName    String
  version         String?
  installedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  computer        Computer   @relation(fields: [computerId], references: [id], onDelete: Cascade)

  @@unique([computerId, softwareName])
}
