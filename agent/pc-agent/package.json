{
  "name": "dyci-pc-agent",
  "version": "1.0.0",
  "description": "Windows PC Agent for DYCI Lab Management System",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "node test.js",
    "build": "pkg . --out-path=dist/",
    "build:installer": "node scripts/build-installer.js",
    "service:install": "node scripts/service-install.js install",
    "service:uninstall": "node scripts/service-install.js uninstall",
    "service:start": "node scripts/service-install.js start",
    "service:stop": "node scripts/service-install.js stop"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "nat-upnp": "^1.1.1",
    "node-powershell": "^5.0.1",
    "node-windows": "^1.0.0-beta.8",
    "screenshot-desktop": "^1.15.3",
    "socket.io-client": "^4.7.4",
    "systeminformation": "^5.21.20",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "pkg": "^5.8.1"
  },
  "bin": "src/index.js",
  "pkg": {
    "scripts": [
      "src/**/*.js"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist"
  }
}
